{
  "expo": {
    "name": "Nexo",
    "slug": "nexo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nexo",
    "userInterfaceStyle": "automatic",

    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#000000"
    },

    "ios": {
      "bundleIdentifier": "com.nexo.app",
      "supportsTablet": true
    },

    "android": {
      "package": "com.nexo.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBDawhwhEmdCe6nqAhdmwSjdu6GQnsIJrs"
        }
      }
    },

    "splash": {
      "image": "./assets/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },

    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "googleServicesFile": "./google-services.json"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splashscreen_logo.png",
          "backgroundColor": "#000000"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3929212574112376~8719443360",
          "iosAppId": "ca-app-pub-3929212574112376~4205483282"
        }
      ]
    ],

    "experiments": {
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "c9b1e493-aacf-48fb-949e-79b89b660718"
      },
      "firebaseProjectId": "nexo-8cc2c",
      "firebaseAppId": "1:730887766171:android:a087587dc23fa88bbd463e",
      "firebaseApiKey": "AIzaSyCRv6eN_Pycp_i5wkTMsk4Qgk9RXyHDgcw",
      "firebaseMessagingSenderId": "730887766171"
    }
  }
}